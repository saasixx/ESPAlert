# ─── ESPAlert Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in the values.
# Values marked REQUIRED must be set before deployment.

# ── Environment ──────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── JWT / Auth ────────────────────────────────────────────────────────
# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_DB=espalert
POSTGRES_USER=espalert
POSTGRES_PASSWORD=           # REQUIRED — set a strong password

# Docker Compose overrides these:
DATABASE_URL=postgresql+asyncpg://espalert:${POSTGRES_PASSWORD}@db:5432/espalert
DATABASE_URL_SYNC=postgresql+psycopg2://espalert:${POSTGRES_PASSWORD}@db:5432/espalert

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=              # REQUIRED — set a password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── External APIs ────────────────────────────────────────────────────
# AEMET OpenData — get your free key at https://opendata.aemet.es
AEMET_API_KEY=

# ── Firebase Push Notifications ──────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT=20/minute
RATE_LIMIT_AUTH=5/minute

# ── Polling Intervals (seconds) ─────────────────────────────────────
AEMET_POLL_INTERVAL=300
IGN_POLL_INTERVAL=120
DGT_POLL_INTERVAL=300
METEOALARM_POLL_INTERVAL=300

# ── Meshtastic Gateway (optional, only if you have a LoRa radio) ────
MESHTASTIC_CONNECTION=serial
MESHTASTIC_ADDRESS=/dev/ttyUSB0

# ── Backup Encryption (optional) ─────────────────────────────────────
BACKUP_GPG_RECIPIENT=        # GPG key ID or email for encrypted backups
