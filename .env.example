# ===========================================================================
# ESPAlert — Variables de entorno
# ===========================================================================
# Copia este archivo a .env y ajusta los valores antes de levantar el stack.
#
#   cp .env.example .env
#
# IMPORTANTE: Nunca subas el archivo .env al repositorio.
# ===========================================================================

# ── Aplicación ─────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=True                       # False en producción
JWT_SECRET=cambia-esto-a-un-secreto-de-al-menos-32-caracteres
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Base de datos (PostgreSQL + PostGIS) ───────────────────────────────────
POSTGRES_USER=espalert
POSTGRES_PASSWORD=changeme
POSTGRES_DB=espalert
DATABASE_URL=postgresql+asyncpg://espalert:changeme@db:5432/espalert
DATABASE_URL_SYNC=postgresql+psycopg2://espalert:changeme@db:5432/espalert

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=devpassword

# ── APIs externas ──────────────────────────────────────────────────────────
# AEMET OpenData (gratuita): https://opendata.aemet.es/centrodedescargas/inicio
AEMET_API_KEY=
# Firebase Cloud Messaging (opcional, para push notifications)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Intervalos de sondeo / Timeouts (segundos) ─────────────────────────────
AEMET_POLL_INTERVAL=300
IGN_POLL_INTERVAL=120
DGT_POLL_INTERVAL=300
METEOALARM_POLL_INTERVAL=300

# ── Límites de tasa / Rate Limiting (Cache) ────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_MESH_SEND=5/minute

# ── Meshtastic ─────────────────────────────────────────────────────────────
MESHTASTIC_CONNECTION=serial
MESHTASTIC_ADDRESS=/dev/ttyUSB0
