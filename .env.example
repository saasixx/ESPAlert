# ======== ESPAlert Example Environment Variables ========
# Rename this file to .env and place it in the root directory before running Docker

# API Configuration
ENVIRONMENT=development
DEBUG=True
JWT_SECRET=super_secret_jwt_string_12345
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql+asyncpg://espalert:changeme@db:5432/espalert
DATABASE_URL_SYNC=postgresql+psycopg2://espalert:changeme@db:5432/espalert
POSTGRES_USER=espalert
POSTGRES_PASSWORD=changeme
POSTGRES_DB=espalert

# Redis
REDIS_URL=redis://redis:6379/0

# External APIs
AEMET_API_KEY=your_aemet_key_here
MAPBOX_TOKEN=your_mapbox_token_here (Optionally, use MapLibre generic)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
